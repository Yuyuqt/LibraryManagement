@using LibraryManagement.Shared.Models
@using BlazorWebAssembly.Services
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject ChatService ChatService
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider

<div class="fixed bottom-6 right-6 z-[100] flex flex-col items-end gap-4 pointer-events-none">
    <!-- Chat Window -->
    @if (_isOpen)
    {
        <div class="pointer-events-auto w-[380px] h-[550px] bg-card border border-border rounded-3xl shadow-2xl flex flex-col overflow-hidden animate-in slide-in-from-bottom-10 duration-300">
            <!-- Header -->
            <div class="bg-primary p-4 flex items-center justify-between text-white shadow-lg relative overflow-hidden">
                <div class="absolute inset-0 bg-white/5 pointer-events-none"></div>
                <div class="flex items-center gap-3 relative z-10">
                    <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center backdrop-blur-md">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"></path></svg>
                    </div>
                    <div>
                        <h3 class="font-black text-sm uppercase tracking-widest">Luxe Librarian</h3>
                        <div class="flex items-center gap-1.5">
                            <div class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></div>
                            <span class="text-[10px] font-bold uppercase tracking-widest opacity-80">AI Assistant</span>
                        </div>
                    </div>
                </div>
                <button @onclick="ToggleChat" class="p-2 hover:bg-white/10 rounded-xl transition-colors relative z-10">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <!-- Messages Area -->
            <div id="chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 bg-body/30 scrollbar-hide">
                @if (!_messages.Any())
                {
                    <div class="h-full flex flex-col items-center justify-center text-center p-8">
                        <div class="w-20 h-20 bg-primary/5 rounded-full flex items-center justify-center mb-6">
                            <svg class="w-10 h-10 text-primary opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                        </div>
                        <h4 class="font-bold text-main mb-2">How can I help you today?</h4>
                        <p class="text-xs text-muted leading-relaxed">Ask me about library plans, book recommendations, or enrichment data!</p>
                        
                        <div class="mt-8 grid grid-cols-1 gap-2 w-full">
                            @foreach (var suggestion in _suggestions)
                            {
                                <button @onclick="() => SendMessage(suggestion)" class="text-[10px] font-black uppercase tracking-widest text-muted hover:text-primary hover:bg-primary/5 border border-border p-3 rounded-xl transition-all text-left">
                                    @suggestion
                                </button>
                            }
                        </div>
                    </div>
                }
                else
                {
                    @foreach (var msg in _messages)
                    {
                        <div class="flex @(msg.Role == "user" ? "justify-end" : "justify-start") animate-in fade-in slide-in-from-bottom-2">
                            <div class="max-w-[85%] @(msg.Role == "user" ? "bg-primary text-white rounded-2xl rounded-tr-none shadow-lg shadow-primary/20" : "bg-card border border-border text-main rounded-2xl rounded-tl-none shadow-sm") p-3">
                                <p class="text-sm leading-relaxed whitespace-pre-wrap">@msg.Content</p>
                                
                                @if (msg.BookData != null)
                                {
                                    <div class="mt-3 bg-body/50 border border-border rounded-xl p-3 flex gap-3">
                                        @if (!string.IsNullOrEmpty(msg.BookData.CoverUrl))
                                        {
                                            <img src="@msg.BookData.CoverUrl" class="w-16 h-24 object-cover rounded-lg shadow-md" alt="Cover" />
                                        }
                                        <div class="flex-1 min-w-0">
                                            <h5 class="text-xs font-black text-main uppercase tracking-widest truncate">@msg.BookData.Title</h5>
                                            <p class="text-[10px] font-bold text-muted uppercase mt-1">@msg.BookData.Author</p>
                                            <p class="text-[9px] text-muted line-clamp-3 mt-2 leading-relaxed">@msg.BookData.Description</p>
                                        </div>
                                    </div>
                                }
                                
                                <div class="mt-1.5 flex @(msg.Role == "user" ? "justify-end" : "justify-start")">
                                    <span class="text-[8px] font-black uppercase opacity-50 tracking-tighter">@msg.Timestamp.ToString("HH:mm")</span>
                                </div>
                            </div>
                        </div>
                    }

                    @if (_isTyping)
                    {
                        <div class="flex justify-start animate-in fade-in">
                            <div class="bg-card border border-border text-main rounded-2xl rounded-tl-none p-3 shadow-sm">
                                <div class="flex gap-1">
                                    <div class="w-1.5 h-1.5 rounded-full bg-primary animate-bounce" style="animation-delay: 0s"></div>
                                    <div class="w-1.5 h-1.5 rounded-full bg-primary animate-bounce" style="animation-delay: 0.2s"></div>
                                    <div class="w-1.5 h-1.5 rounded-full bg-primary animate-bounce" style="animation-delay: 0.4s"></div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Input Area -->
            <div class="p-4 bg-card border-t border-border">
                <div class="relative">
                    <input @bind="_userInput" @bind:event="oninput" @onkeydown="HandleKeyDown" 
                           type="text" placeholder="Type your message..." 
                           class="w-full bg-body border border-border rounded-2xl pl-4 pr-12 py-3.5 text-sm focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all shadow-sm" />
                    <button @onclick="() => SendMessage()" disabled="@(string.IsNullOrWhiteSpace(_userInput) || _isTyping)"
                            class="absolute right-2 top-1/2 -translate-y-1/2 p-2 bg-primary text-white rounded-xl hover:bg-primary-hover disabled:opacity-30 disabled:cursor-not-allowed transition-all shadow-lg shadow-primary/20">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
                    </button>
                </div>
                <div class="mt-3 flex items-center justify-between">
                    <span class="text-[9px] font-bold text-muted uppercase tracking-widest">LibraryLuxe AI v1.0</span>
                    <button @onclick="ClearChat" class="text-[9px] font-bold text-red-500/60 hover:text-red-500 uppercase tracking-widest transition-colors">Clear History</button>
                </div>
            </div>
        </div>
    }

    <!-- Toggle Button -->
    <button @onclick="ToggleChat" class="pointer-events-auto w-16 h-16 bg-primary text-white rounded-full flex items-center justify-center shadow-2xl hover:scale-110 active:scale-95 transition-all group relative">
        <div class="absolute inset-0 rounded-full bg-primary animate-ping opacity-20 group-hover:hidden"></div>
        @if (_isOpen)
        {
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path></svg>
        }
        else
        {
            <div class="relative">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                <div class="absolute -top-1 -right-1 w-3 h-3 bg-green-400 border-2 border-primary rounded-full"></div>
            </div>
        }
    </button>
</div>

@code {
    private bool _isOpen = false;
    private string _userInput = string.Empty;
    private List<ChatMessage> _messages = new();
    private bool _isTyping = false;
    private string[] _suggestions = {
        "Tell me about library plans",
        "How can I earn rewards?",
        "Recommend me books",
        "How to renew subscription?"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadHistory();
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        await InvokeAsync(async () => {
            await LoadHistory();
            StateHasChanged();
        });
    }

    private async Task LoadHistory()
    {
        _messages = await ChatService.GetHistoryAsync();
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }

    private async Task ToggleChat()
    {
        _isOpen = !_isOpen;
        if (_isOpen)
        {
            await Task.Delay(100);
            await ScrollToBottom();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_userInput) && !_isTyping)
        {
            await SendMessage();
        }
    }

    private async Task SendMessage(string? text = null)
    {
        var content = text ?? _userInput;
        if (string.IsNullOrWhiteSpace(content) || _isTyping) return;

        var userMsg = new ChatMessage { Content = content, Role = "user" };
        _messages.Add(userMsg);
        _userInput = string.Empty;
        _isTyping = true;
        
        await ScrollToBottom();
        await ChatService.SaveHistoryAsync(_messages);

        var response = await ChatService.SendMessageAsync(content, _messages);
        
        _isTyping = false;
        if (response != null)
        {
            var assistantMsg = new ChatMessage 
            { 
                Content = response.Response, 
                Role = "assistant",
                BookData = response.BookData 
            };
            _messages.Add(assistantMsg);
            await ChatService.SaveHistoryAsync(_messages);
        }
        else
        {
            _messages.Add(new ChatMessage { Content = "Critical Error: No response from ChatService. Check console.", Role = "assistant" });
        }

        await ScrollToBottom();
    }

    private async Task ClearChat()
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Clear all chat history?");
        if (confirmed)
        {
            _messages.Clear();
            await ChatService.ClearHistoryAsync();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(50);
        await JS.InvokeVoidAsync("eval", "document.getElementById('chat-messages')?.scrollTo({ top: 100000, behavior: 'smooth' })");
    }
}
